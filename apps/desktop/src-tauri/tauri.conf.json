{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Antigravity Tools LS",
  "version": "0.0.2",
  "identifier": "com.antigravity.tools.ls.clean",
  "build": {
    "beforeDevCommand": "cd ../web-dashboard && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "cd ../web-dashboard && npm run build",
    "frontendDist": "../../web-dashboard/dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Antigravity Tools LS",
        "width": 1300,
        "height": 900,
        "maximized": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
